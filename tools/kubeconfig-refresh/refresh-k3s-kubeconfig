#!/usr/bin/env bash
# Refresh the k3s admin client cert in ~/.kube/config from kube-master.
# k3s rotates the admin cert (+1y) whenever the service restarts within 90
# days of expiry; the master's copy stays valid but the local one goes stale.
# Run monthly by refresh-k3s-kubeconfig.timer (systemd user unit).
set -euo pipefail

MASTER=kube-master
KUBECONFIG_FILE="$HOME/.kube/config"
USER_ENTRY=default

remote=$(ssh -o BatchMode=yes -o ConnectTimeout=10 "$MASTER" \
  "sudo grep -E 'client-(certificate|key)-data' /etc/rancher/k3s/k3s.yaml")

cert=$(awk '/client-certificate-data/{print $2}' <<<"$remote")
key=$(awk '/client-key-data/{print $2}' <<<"$remote")
if [[ -z $cert || -z $key ]]; then
  echo "failed to extract cert/key from $MASTER k3s.yaml" >&2
  exit 1
fi

cert_pem=$(base64 -d <<<"$cert")
end=$(openssl x509 -noout -enddate <<<"$cert_pem")
if ! openssl x509 -checkend $((30 * 86400)) -noout <<<"$cert_pem" >/dev/null; then
  echo "WARNING: master's admin cert expires soon ($end) — k3s on $MASTER needs a service restart to rotate it" >&2
fi

# the cert and key must be a matching pair before we install them
cert_pub=$(openssl x509 -noout -pubkey <<<"$cert_pem")
key_pub=$(base64 -d <<<"$key" | openssl pkey -pubout 2>/dev/null)
if [[ "$cert_pub" != "$key_pub" ]]; then
  echo "fetched key does not match fetched cert; aborting" >&2
  exit 1
fi

current=$(kubectl config view --raw \
  -o jsonpath="{.users[?(@.name==\"$USER_ENTRY\")].user.client-certificate-data}")
if [[ "$current" == "$cert" ]]; then
  echo "kubeconfig already current ($end)"
  exit 0
fi

cp "$KUBECONFIG_FILE" "$KUBECONFIG_FILE.bak-$(date +%Y%m%d%H%M%S)"
kubectl config set "users.$USER_ENTRY.client-certificate-data" "$cert" >/dev/null
kubectl config set "users.$USER_ENTRY.client-key-data" "$key" >/dev/null
chmod 600 "$KUBECONFIG_FILE"
echo "updated user '$USER_ENTRY' in $KUBECONFIG_FILE ($end)"
